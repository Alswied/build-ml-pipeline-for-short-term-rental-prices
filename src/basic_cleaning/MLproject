name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        type: str
        description: Raw dataset artifact
      output_artifact:
        type: str
        description: Name of cleaned dataset artifact
      output_type:
        type: str
        description: Type of the cleaned artifact
      output_description:
        type: str
        description: Description of the cleaned data
      min_price:
        type: float
        description: Minimum allowed price
      max_price:
        type: float
        description: Maximum allowed price

    command: >
      python run.py
      --input_artifact {input_artifact}
      --output_artifact {output_artifact}
      --output_type {output_type}
      --output_description "{output_description}"
      --min_price {min_price}
      --max_price {max_price}
